# Adobe PDF Services API — required for PDF → Word conversion.
# Obtain from: https://developer.adobe.com/document-services/apis/pdf-services/
ADOBE_CLIENT_ID="YOUR_ADOBE_CLIENT_ID"
ADOBE_CLIENT_SECRET="YOUR_ADOBE_CLIENT_SECRET"

# Optional: port for local development (default: 5173)
# PORT=5173
# Optional: host for local development (default: 127.0.0.1)
# HOST=127.0.0.1

# Notion integration — required for Test Center progress list.
# NOTION_PROGRESS_DATABASE_ID should be the database ID of the "進捗管理" table.
NOTION_API_KEY="YOUR_NOTION_INTEGRATION_SECRET"
NOTION_PROGRESS_DATABASE_ID="YOUR_NOTION_DATABASE_ID"

# Browserless — required for データ収集 (時事速報).
# Obtain from: https://www.browserless.io/
BROWSERLESS_TOKEN="YOUR_BROWSERLESS_TOKEN"
